# ─── LLM (provider-agnostic via init_chat_model) ──────────────────────────────
# Default uses OpenAI. To use Claude instead, set:
#   LLM_MODEL=anthropic:claude-haiku-4-5-20251001   and add ANTHROPIC_API_KEY
LLM_MODEL=openai:gpt-4o-mini
OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# ─── Demand data: SerpApi (https://serpapi.com) ───────────────────────────────
# Free tier ~250 searches/month. Leave empty to run the demand side in mock mode.
SERPAPI_API_KEY=

# ─── Supply data: Oxylabs Amazon Scraper API ──────────────────────────────────
# Leave empty to run the supply side in mock mode (saved fixtures).
OXYLABS_USERNAME=
OXYLABS_PASSWORD=

# ─── Markets ──────────────────────────────────────────────────────────────────
AMAZON_DOMAIN=in          # default Amazon marketplace: in, com, co.uk, de, ca, com.au, ae, co.jp

# ─── Memory / checkpointer ────────────────────────────────────────────────────
# Redis is the default checkpointer. Use a local Redis or a Redis Cloud URI:
#   redis://default:<password>@<host>:<port>
# If REDIS_URI is empty or unreachable, the app falls back to SQLite automatically.
REDIS_URI=redis://localhost:6379
# SQLITE_PATH=launchlens_checkpoints.sqlite

# ─── Summarization knobs ──────────────────────────────────────────────────────
MAX_MESSAGES=12           # summarize once a thread grows past this many messages
KEEP_LAST=6               # keep this many recent messages verbatim
